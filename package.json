{
  "name": "jobsnap",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm install --workspaces --include-workspace-root --no-audit --no-fund && npm run dev:workspaces",
    "dev:workspaces": "npm run dev --workspace backend & npm run dev --workspace frontend",
    "dev:backend": "npm run dev --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "lint": "npm run lint --workspace backend && npm run lint --workspace frontend",
    "build": "npm run build --workspace frontend"
  }
}
